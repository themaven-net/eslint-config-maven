{
    "name": "@themaven-net/eslint-config-maven",
    "version": "12.0.2",
    "type": "module",
    "description": "TheMaven's eslint config",
    "main": "./index.js",
    "exports": {
        ".": "./index.js",
        "./base-tsconfig.json": "./base-tsconfig.json",
        "./.prettierrc": "./.prettierrc.js",
        "./eslint-strict.js": "./eslint-strict.js",
        "./*": null
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "lint": "eslint .",
        "test": "yarn run lint"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/themaven-net/eslint-config-maven.git"
    },
    "keywords": [
        "eslint",
        "eslintconfig"
    ],
    "author": "TheMaven",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/themaven-net/eslint-config-maven/issues"
    },
    "homepage": "https://github.com/themaven-net/eslint-config-maven#readme",
    "dependencies": {
        "@eslint/js": "^9",
        "eslint": "^9",
        "eslint-config-prettier": "^9",
        "eslint-plugin-import-x": "^4",
        "eslint-plugin-jest": "^29",
        "eslint-plugin-prettier": "^5",
        "eslint-plugin-simple-import-sort": "^12",
        "globals": "^16",
        "prettier": "^3",
        "typescript": "^5",
        "typescript-eslint": "^8"
    },
    "peerDependencies": {
        "eslint": ">= 9"
    },
    "packageManager": "yarn@4.12.0"
}
